MaterialsConfig(
    default: (
        // must match material pass layout
        object_layout: [
            VertexBufferAddress,
        ],
        vertex_attributes: "POSITION | COLOR | TEXTURE | NORMAL | TANGENT | BITANGENT",
        color_format: R16g16b16a16Sfloat,
        depth_format: D32Sfloat,
    ),
    materials: {
      "ui": (
            vertex_shader: "ui.vert.spv",
            vertex_entry: "main",
            fragment_shader: "ui.frag.spv",
            fragment_entry: "main",
            cull_mode: None,
            blend_mode: Premultiplied,
            texture_layout: [
                Diffuse,
            ],
        ),
    }
)
